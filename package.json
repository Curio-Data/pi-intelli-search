{
  "name": "@curio-data/pi-intelli-search",
  "version": "0.3.1-alpha.1",
  "description": "Intelligent web research for Pi: search, extract, collate, and cache grounded web context in one tool call.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Curio-Data/pi-intelli-search.git"
  },
  "bugs": {
    "url": "https://github.com/Curio-Data/pi-intelli-search/issues"
  },
  "homepage": "https://github.com/Curio-Data/pi-intelli-search#readme",
  "type": "module",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
