{
  "name": "pi-web-research",
  "version": "0.1.0",
  "description": "Web research extension for Pi: search, extract, collate, cache with persistent .search/ directory.",
  "type": "module",
  "pi": {
    "extensions": ["./src/index.ts"],
    "skills": ["./skills"]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --import tsx --test test/*.test.ts",
    "test:smoke": "node --import tsx test/smoke.ts"
  },
  "dependencies": {
    "wreq-js": "^2.3.0",
    "defuddle": "^0.16.0",
    "linkedom": "^0.18.12"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "files": [
    "src/",
    "skills/",
    "README.md"
  ],
  "keywords": [
    "pi-package"
  ]
}
