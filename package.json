  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.72.1",
    "@mariozechner/pi-coding-agent": "^0.72.1",
    "typebox": "*",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "typebox": "*"
  },
  "files": [
    "src/",
    "skills/",
    "dist/",
    "docs/CHANGELOG.md",
    "NOTICE",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "pi-package",
    "pi-extension",
    "web-research",
    "web-search",
    "intelli-search"
  ]
